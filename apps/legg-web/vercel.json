{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://server-production-6135.up.railway.app/api/$1"
    },
    {
      "src": "/trpc/(.*)",
      "dest": "https://server-production-6135.up.railway.app/trpc/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
